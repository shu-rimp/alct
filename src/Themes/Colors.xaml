<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="AppBgColor">#0A0B16</Color>
    <Color x:Key="SurfaceBgColor">#13142A</Color>
    <Color x:Key="CardBgColor">#1A1D38</Color>
    <Color x:Key="InputBgColor">#12132A</Color>
    <!-- Border -->
    <Color x:Key="BorderColor">#262A4A</Color>
    <Color x:Key="CardBorderAccentColor">#2E3358</Color>
    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E8E8F2</Color>
    <Color x:Key="TextSecondaryColor">#B0B2CC</Color>
    <Color x:Key="TextMutedColor">#8588A8</Color>
    <Color x:Key="TextDangerColor">#F87171</Color>
    <Color x:Key="TextWarnColor">#F0A868</Color>
    <Color x:Key="TextSuccessColor">#4ADE80</Color>
    <!-- Accent -->
    <Color x:Key="AccentColor">#818CF8</Color>
    <Color x:Key="AccentHoverColor">#6E78E8</Color>
    <Color x:Key="AccentPressedColor">#5B64D8</Color>
    <Color x:Key="AccentSoftColor">#A5B4FC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="{StaticResource SurfaceBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="CardBorderAccentBrush" Color="{StaticResource CardBorderAccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDangerBrush" Color="{StaticResource TextDangerColor}"/>
    <SolidColorBrush x:Key="TextWarnBrush" Color="{StaticResource TextWarnColor}"/>
    <SolidColorBrush x:Key="TextSuccessBrush" Color="{StaticResource TextSuccessColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- Overlay (rgba(22,20,31,0.92)) -->
    <Color x:Key="OverlayBgColor">#B316141F</Color>
    <SolidColorBrush x:Key="OverlayBgBrush" Color="{StaticResource OverlayBgColor}"/>

    <!-- WPF-UI ToggleSwitch On 상태 오버라이드 -->
    <SolidColorBrush x:Key="ToggleSwitchFillOn"              Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchStrokeOn"            Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="{StaticResource AccentHoverColor}"/>
    <!-- WPF-UI ToggleSwitch Knob(thumb) ON 상태 흰색 유지 -->
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn"            Color="White"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="White"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed"     Color="#F0F0F0"/>

    <!-- Elevated input background (combo box) -->
    <Color x:Key="ComboBgColor">#20234A</Color>
    <SolidColorBrush x:Key="ComboBgBrush" Color="{StaticResource ComboBgColor}"/>

    <!-- Dimensions -->
    <CornerRadius x:Key="WindowRadius">12</CornerRadius>
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
    <CornerRadius x:Key="PillRadius">20</CornerRadius>
    <Thickness x:Key="CardPadding">16,12,16,12</Thickness>
    <Thickness x:Key="SectionSpacing">0,20,0,0</Thickness>

</ResourceDictionary>
