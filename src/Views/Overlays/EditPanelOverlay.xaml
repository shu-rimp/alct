<Window x:Class="AlctClient.Views.Overlays.EditPanelOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EditPanelOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <Style x:Key="PanelBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBgBrush}"
            CornerRadius="{StaticResource CardRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">
        <StackPanel Margin="16,12,16,12">

            <!-- 불투명도 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="불투명도"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Slider x:Name="OpacitySlider"
                        Width="160"
                        Minimum="10" Maximum="100"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="OnOpacityChanged"/>
                <TextBlock x:Name="OpacityValueText"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" Width="36"/>
            </StackPanel>

            <!-- 글자 크기 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="글자 크기"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Slider x:Name="FontSizeSlider"
                        Width="160"
                        Minimum="10" Maximum="24"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="OnFontSizeChanged"/>
                <TextBlock x:Name="FontSizeValueText"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" Width="36"/>
            </StackPanel>

            <!-- 초기화 / 취소 / 저장 -->
            <Grid Margin="0,10,0,0">
                <Button Content="초기화"
                        Foreground="{StaticResource TextMutedBrush}"
                        Background="Transparent"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Style="{StaticResource PanelBtn}"
                        HorizontalAlignment="Left"
                        Click="OnReset"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Style="{StaticResource PanelBtn}"
                            Margin="0,0,8,0"
                            Click="OnCancel"/>
                    <Button Content="저장"
                            Foreground="White"
                            Background="{StaticResource AccentBrush}"
                            Style="{StaticResource PanelBtn}"
                            Click="OnSave"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</Window>
