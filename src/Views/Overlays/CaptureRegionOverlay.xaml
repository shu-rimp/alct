<Window x:Class="AlctClient.Views.Overlays.CaptureRegionOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        MinWidth="100" MinHeight="50"
        SizeChanged="OnSizeChanged">

    <Window.Resources>
        <Style x:Key="EditBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- 영역 외곽선 -->
        <Rectangle Stroke="#FF8B7CF8" StrokeThickness="2"
                   Fill="#90000000"/>

        <!-- 상단 가이드 텍스트 -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0"
                    IsHitTestVisible="False">
            <TextBlock Text="게임 내 채팅창을 열고 메시지가 표시되는 영역을 지정하세요."
                       Foreground="White" FontSize="13" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="스크롤바 · 텍스트 입력창 등을 제외해야 정확합니다"
                       Foreground="#BBBBBB" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <!-- 하단 크기 표시 + 버튼 + 가이드 바 -->
        <StackPanel VerticalAlignment="Bottom">
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                <TextBlock x:Name="SizeLabel"
                           Foreground="White" FontSize="11" FontFamily="Consolas"
                           HorizontalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <StackPanel Orientation="Horizontal">
                    <Button Content="취소"
                            Style="{StaticResource EditBtn}"
                            Background="#90000000" Foreground="White"
                            Margin="0,0,6,0"
                            Click="OnCancel"/>
                    <Button Content="저장"
                            Style="{StaticResource EditBtn}"
                            Background="#FF8B7CF8" Foreground="White"
                            Click="OnSave"/>
                </StackPanel>
            </StackPanel>
            <Border Background="#CC8B7CF8" Padding="0,5" IsHitTestVisible="False">
                <TextBlock Text="상하좌우 가장자리를 드래그하여 크기 조절"
                           Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

    </Grid>
</Window>
