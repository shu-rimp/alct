<Window x:Class="AlctClient.Views.Overlays.ChatTranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AlctClient.Views.Overlays"
        Title="ChatTranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="280"
        MinWidth="200" MaxWidth="600">

    <Border x:Name="RootBorder"
            Background="{StaticResource OverlayBgBrush}"
            CornerRadius="{StaticResource CardRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="OnMouseLeftButtonDown">

        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="12,9,12,9">
                <Ellipse Width="7" Height="7"
                         Fill="#4CAF50"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                <TextBlock Text="ALCT 채팅번역"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 번역 중 스피너 (기본 숨김) -->
            <StackPanel x:Name="LoadingRow" Orientation="Horizontal"
                        Visibility="Collapsed"
                        Margin="12,0,12,10">
                <Grid Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse x:Name="Spinner"
                             Width="14" Height="14"
                             Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="2"
                             StrokeDashArray="4 100"
                             StrokeDashCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                <TextBlock x:Name="LoadingText"
                           Text="번역 중…"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 안내/오류 메시지 (기본 숨김) — '번역 중…'과 동일한 작은 보조색 스타일 -->
            <TextBlock x:Name="NoticeText"
                       Visibility="Collapsed"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="12,0,12,10"/>

            <!-- Translation entries -->
            <ItemsControl x:Name="EntriesList" Margin="0,0,0,4"
                          HorizontalContentAlignment="Stretch">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:TranslationEntry}">
                        <StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                            <StackPanel Margin="12,8,12,8">
                                <TextBlock Text="{Binding Translated}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="{DynamicResource OverlayFontSizeMain}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Original}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="{DynamicResource OverlayFontSizeSub}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 편집 모드 안내 바 (기본 숨김) -->
            <Border x:Name="EditModeBar"
                    Visibility="Collapsed"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="0,0,8,8"
                    Padding="0,5">
                <TextBlock Text="← 좌우 가장자리를 드래그하여 너비 조절 · 나머지 영역을 드래그하여 이동"
                           Foreground="White"
                           FontSize="10"
                           HorizontalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
