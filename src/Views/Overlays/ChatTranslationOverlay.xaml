<Window x:Class="AlctClient.Views.Overlays.ChatTranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatTranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False">

    <!-- 캡처 영역을 덮는 투명 창. 번역문은 원문 위치 위에 캔버스로 배치된다. -->
    <Grid>
        <Canvas x:Name="RegionCanvas"/>

        <!-- 상태 표시(번역 중 / 안내·오류) — 영역 좌상단의 작은 알약. 번역 결과엔 부가 요소가 없다. -->
        <Border x:Name="StatusPill"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#CC000000"
                CornerRadius="4"
                Padding="10,6"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Grid x:Name="SpinnerBox" Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center">
                    <Ellipse x:Name="Spinner"
                             Width="13" Height="13"
                             Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="2"
                             StrokeDashArray="4 100"
                             StrokeDashCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                <TextBlock x:Name="StatusText"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
