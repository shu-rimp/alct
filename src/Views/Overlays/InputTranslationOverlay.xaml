<Window x:Class="AlctClient.Views.Overlays.InputTranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InputTranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MaxWidth="460">

    <Border Background="{StaticResource OverlayBgBrush}"
            CornerRadius="{StaticResource PillRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            Padding="14,9">
        <StackPanel Orientation="Horizontal">

            <!-- 상태 인디케이터: 로딩 스피너 또는 정적 점 -->
            <Grid Width="14" Height="14" Margin="0,1,10,0" VerticalAlignment="Top">
                <!-- 로딩 스피너 (회전) -->
                <Ellipse x:Name="Spinner"
                         Width="14" Height="14"
                         Stroke="{StaticResource AccentBrush}"
                         StrokeThickness="2"
                         StrokeDashArray="4 100"
                         StrokeDashCap="Round"
                         Visibility="Collapsed"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- 완료/안내 점 -->
                <Ellipse x:Name="StatusDot"
                         Width="8" Height="8"
                         Fill="{StaticResource TextSuccessBrush}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
            </Grid>

            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="MessageText"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="HintText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,3,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
