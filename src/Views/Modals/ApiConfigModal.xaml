<Window x:Class="AlctClient.Views.Modals.ApiConfigModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="380" Height="240"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="InputActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel Margin="24,22,24,22">
            <TextBlock x:Name="DialogTitleText"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <TextBlock Text="API 키를 복사한 후 붙여넣기 버튼을 눌러주세요."
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource InputBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ButtonRadius}">
                    <Grid>
                        <TextBlock x:Name="ApiKeyPlaceholder"
                                   Text=""
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" Padding="10,8"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     BorderThickness="0"
                                     FontSize="13" Padding="10,8"
                                     Focusable="False"
                                     PasswordChanged="OnApiKeyPasswordChanged"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                    <Button Content="붙여넣기"
                            Style="{StaticResource InputActionButton}"
                            Margin="0,0,4,0"
                            Click="OnPaste"/>
                    <Button Content="삭제"
                            Style="{StaticResource InputActionButton}"
                            Click="OnClear"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="⚠ 해당 키는 절대 타인에게 노출하지 마세요."
                       Foreground="{StaticResource TextDangerBrush}"
                       FontSize="12"
                       Margin="0,0,0,18"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Click="OnCancel" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="16,7"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="저장" Click="OnSave">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="16,7"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
