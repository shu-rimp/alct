<Window x:Class="AlctClient.Views.Modals.ApiConfigModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:AlctClient.Utils"
        Title="번역 엔진 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="480" Height="600"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="SidebarItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarItemActive" TargetType="Button" BasedOn="{StaticResource SidebarItem}">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="InputActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="18,16,18,0">
                <TextBlock Text="번역 엔진 설정"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="15" Click="OnCancel">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- 구분선 -->
            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="0,46,0,0"/>

            <!-- 바디 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 사이드바 -->
                <StackPanel Grid.Column="0" Margin="10,10,10,10">
                    <Button x:Name="SidebarMyMemory" Style="{StaticResource SidebarItem}"
                            Click="OnSelectMyMemory" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MyMemory" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SidebarDeepL" Style="{StaticResource SidebarItemActive}"
                            Click="OnSelectDeepL">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DeepL" VerticalAlignment="Center"/>
                            <Ellipse x:Name="DotDeepL" Width="6" Height="6"
                                     Fill="#4ade80" Margin="8,0,0,0" VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SidebarGemini" Style="{StaticResource SidebarItem}"
                            Click="OnSelectGemini" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Gemini" VerticalAlignment="Center"/>
                            <Ellipse x:Name="DotGemini" Width="6" Height="6"
                                     Fill="#4ade80" Margin="8,0,0,0" VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 세로 구분선 -->
                <Border Grid.Column="1" Width="1"
                        Background="{StaticResource BorderBrush}"
                        Margin="0,10,0,10"/>

                <!-- 우측 콘텐츠 -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="18,14,18,14">
                    <StackPanel>
                        <!-- 키 입력 -->
                        <TextBlock x:Name="KeyLabel"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" Margin="0,0,0,7"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{StaticResource InputBgBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ButtonRadius}">
                                <Grid>
                                    <TextBlock x:Name="ApiKeyPlaceholder"
                                               Text="붙여넣기 버튼 클릭"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Padding="10,8"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="ApiKeyBox"
                                                 Background="Transparent"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 CaretBrush="{StaticResource AccentBrush}"
                                                 BorderThickness="0"
                                                 FontSize="12" Padding="10,8"
                                                 Focusable="False"
                                                 PasswordChanged="OnApiKeyPasswordChanged"/>
                                    <!-- MyMemory 이메일 입력 (마스킹 없음, 직접 타이핑 가능) -->
                                    <TextBox x:Name="EmailBox"
                                             Background="Transparent"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="{StaticResource AccentBrush}"
                                             BorderThickness="0"
                                             FontSize="12" Padding="10,8"
                                             Visibility="Collapsed"
                                             TextChanged="OnEmailChanged"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                                <Button Content="붙여넣기" Style="{StaticResource InputActionButton}"
                                        Margin="0,0,4,0" Click="OnPaste"/>
                                <Button Content="삭제" Style="{StaticResource InputActionButton}"
                                        Click="OnClear"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="KeyValidLabel"
                                   Foreground="#4ade80" FontSize="11"
                                   Margin="0,0,0,6" Visibility="Collapsed"
                                   Text="✓ 유효한 키입니다"/>
                        <TextBlock x:Name="KeyShareNotice"
                                   Text="🔒 API 키는 절대 타인에게 공유하지 마세요."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,12"/>

                        <!-- 사용량 게이지 (DeepL 전용 — Gemini는 키만으로 사용량 조회 불가) -->
                        <Border x:Name="UsageBox"
                                Background="{StaticResource InputBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="7"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <TextBlock Text="API 문자 사용량"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"/>
                                    <TextBlock x:Name="UsageText"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                </Grid>
                                <Border Background="{StaticResource CardBgBrush}"
                                        CornerRadius="3" Height="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="UsageFillCol" Width="0*"/>
                                            <ColumnDefinition x:Name="UsageRestCol" Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="UsageFill" Grid.Column="0"
                                                Background="#4ade80" CornerRadius="3"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,0,0,12"/>

                        <!-- 발급 가이드 -->
                        <TextBlock x:Name="GuideTitle"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="GuideLinkBtn"
                                FontSize="12" Cursor="Hand"
                                Margin="0,0,0,8" Click="OnOpenGuideLink">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="8,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="UsageLinkBtn" Grid.Column="0"
                                    FontSize="12" Cursor="Hand"
                                    Click="OnOpenUsageLink">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="8,8"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <utils:HintIcon x:Name="UsageHint" Grid.Column="1"
                                            Margin="6,0,0,0" VerticalAlignment="Center"
                                            Visibility="Collapsed"/>
                        </Grid>
                        <ItemsControl x:Name="GuideSteps" Margin="0,0,0,8"
                                      HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Number}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Top"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border x:Name="WarnBox"
                                Background="#14F0A868"
                                BorderBrush="#4DF0A868"
                                BorderThickness="1" CornerRadius="7"
                                Padding="10,8" Visibility="Collapsed">
                            <TextBlock x:Name="WarnText"
                                       Foreground="#F0A868"
                                       FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                        </Border>

                        <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,16,0,0"
                                   TextWrapping="Wrap" LineHeight="17">
                            <Run Text="번역 서비스의 무료 요금제는 입력 내용이 품질 개선·학습이나 번역 메모리 보관에 쓰일 수 있어요. "/><Hyperlink Click="OnOpenTerms" Foreground="{StaticResource AccentBrush}">자세히 보기</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 푸터 -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="18,12,18,14">
                    <Button Content="취소" Click="OnCancel" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="16,7"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="SaveBtn" Content="저장" Click="OnSave">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="16,7"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.35"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
