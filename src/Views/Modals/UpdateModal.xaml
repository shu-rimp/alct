<Window x:Class="AlctClient.Views.Modals.UpdateModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업데이트 사용 가능"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="380" Height="296"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel Margin="24,22,24,22">

            <TextBlock Text="업데이트 알림"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="새로운 버전이 있어요!"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="현재 버전"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,2"/>
                    <TextBlock x:Name="CurrentVersionText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="최신 버전"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,2"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="LatestVersionText"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="변경 사항"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" Margin="0,0,0,6"/>

            <Border Background="{StaticResource InputBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardRadius}"
                    Height="68"
                    Margin="0,0,0,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,8">
                    <TextBlock x:Name="ReleaseNotesText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="나중에" Click="OnClose" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="16,7"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="다운로드" Click="OnDownload">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="16,7"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
