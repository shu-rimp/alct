<Window x:Class="AlctClient.Views.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:utils="clr-namespace:AlctClient.Utils"
        Title="ALCT 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Width="400" Height="640"
        MinWidth="400" MinHeight="460" MaxHeight="860">

    <Window.Resources>

        <!-- ── 탭 버튼: 활성 ── -->
        <Style x:Key="TabButtonActive" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 탭 버튼: 비활성 ── -->
        <Style x:Key="TabButtonInactive" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ── -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ComboBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="root">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <Grid Margin="10,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                            <ToggleButton Style="{x:Null}"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, ElementName=root}"
                                        MaxHeight="180"
                                        Background="{StaticResource ComboBgBrush}"
                                        BorderBrush="{StaticResource CardBorderAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 단축키 뱃지 ── -->
        <Style x:Key="HotkeyBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <!-- ── 소형 버튼 ── -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── API 설정 버튼 (gear) ── -->
        <Style x:Key="GearButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
            <Setter Property="Background"   Value="{StaticResource ComboBgBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource CardBorderAccentBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="8,3"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,16,0,0"/>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="OnHeaderDrag">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Grid Grid.Row="0" Margin="18,16,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="WordmarkImage" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" HorizontalAlignment="Left"/>

                <Button Grid.Column="1" Content="✕"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="15" Click="OnClose">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="6">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ── 탭 바 (3개) ── -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="18,12,18,0">
                <Button x:Name="TabTranslationBtn" Content="번역"
                        Style="{StaticResource TabButtonActive}"
                        Click="OnTabTranslation"/>
                <Button x:Name="TabHotkeyBtn" Content="단축키"
                        Style="{StaticResource TabButtonInactive}"
                        Margin="4,0,0,0" Click="OnTabHotkey"/>
                <Button x:Name="TabScreenBtn" Content="화면"
                        Style="{StaticResource TabButtonInactive}"
                        Margin="4,0,0,0" Click="OnTabScreen"/>
            </StackPanel>

            <!-- ── 콘텐츠 ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <Border Padding="20,28,20,40">
                <Grid>

                    <!-- ══════════ 탭1: 번역 ══════════ -->
                    <StackPanel x:Name="PanelTranslation" Visibility="Visible">

                        <!-- 번역 언어 -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="번역 언어"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <utils:HintIcon Margin="4,0,0,0" VerticalAlignment="Center"
                                                Guide="한국어로 번역할 언어를 선택하세요."/>
                            </StackPanel>
                            <ComboBox x:Name="SourceLangCombo"
                                      Width="150" HorizontalAlignment="Left"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnSourceLangChanged">
                                <ComboBoxItem Content="일본어" Tag="ja-JP" IsSelected="True"/>
                                <ComboBoxItem Content="중국어" Tag="zh-CN"/>
                                <ComboBoxItem Content="영어"   Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>

                        <Separator Margin="0,26,0,22"/>

                        <!-- 번역 엔진 헤더 -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="번역 엔진"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="설정"
                                    Style="{StaticResource GearButton}"
                                    Click="OnApiSettingsClick"/>
                        </Grid>

                        <!-- 채팅 번역 카드 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="💬 채팅 번역"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="175"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="번역 엔진"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13" VerticalAlignment="Top"
                                               Margin="0,9,0,0"/>
                                    <ComboBox x:Name="TextEngineCombo"
                                              Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              SelectionChanged="OnTextEngineChanged">
                                        <ComboBoxItem Tag="MyMemory" IsSelected="True">
                                            <StackPanel>
                                                <TextBlock Text="MyMemory" FontSize="13"/>
                                                <TextBlock Text="키 없이 바로 사용" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem Tag="DeepL">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="DeepL" FontSize="13" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource ComboBgBrush}"
                                                            BorderBrush="{StaticResource CardBorderAccentBrush}"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="고품질 번역 · API 키 필요" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem Tag="Gemini">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Gemini" FontSize="13" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource ComboBgBrush}"
                                                            BorderBrush="{StaticResource CardBorderAccentBrush}"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="AI 번역 · API 키 필요" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                                <TextBlock x:Name="TextApiKeyWarning"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextWarnBrush}"
                                           FontSize="11" Margin="0,6,0,0"
                                           Text="⚠️ [설정]에서 API 키를 입력해주세요."/>
                            </StackPanel>
                        </Border>

                        <!-- 음성 번역 카드 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🎙️ 실시간 음성 번역"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="VoiceHintText"
                                                   Text="Windows11 22H2 이상 필요"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch x:Name="CaptionMonitorToggle"
                                                     Grid.Column="1"
                                                     VerticalAlignment="Center"
                                                     IsChecked="False"
                                                     Checked="OnCaptionModeChanged"
                                                     Unchecked="OnCaptionModeChanged"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="175"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="번역 엔진"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13" VerticalAlignment="Top"
                                               Margin="0,9,0,0"/>
                                    <ComboBox x:Name="VoiceEngineCombo"
                                              Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              IsEnabled="{Binding IsChecked, ElementName=CaptionMonitorToggle}"
                                              SelectionChanged="OnVoiceEngineChanged">
                                        <ComboBoxItem Tag="MyMemory" IsSelected="True">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="MyMemory" FontSize="13"/>
                                                    <Border Background="{StaticResource ComboBgBrush}"
                                                            BorderBrush="{StaticResource CardBorderAccentBrush}"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="키 없이 바로 사용" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem Tag="DeepL">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="DeepL" FontSize="13" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource ComboBgBrush}"
                                                            BorderBrush="{StaticResource CardBorderAccentBrush}"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="고품질 번역 · API 키 필요" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem Tag="Gemini">
                                            <StackPanel>
                                                <TextBlock Text="Gemini" FontSize="13"/>
                                                <TextBlock Text="AI 번역 · API 키 필요" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </Grid>
                                <TextBlock x:Name="VoiceApiKeyWarning"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextWarnBrush}"
                                           FontSize="11" Margin="0,6,0,0"
                                           Text="⚠️ [설정]에서 API 키를 입력해주세요."/>
                                <TextBlock x:Name="VoiceGeminiNote"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="Gemini를 음성 번역에 사용 시 무료 한도가 빨리 소진되거나, 번역이 늦게 보일 수 있어요."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="DeepL·Gemini는 무료 사용량 한도 도달 시 번역이 제한돼요. 무료 한도가 소진되면 다른 번역 엔진을 사용해 주세요."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="2,16,2,0"/>

                    </StackPanel>

                    <!-- ══════════ 탭2: 단축키 ══════════ -->
                    <StackPanel x:Name="PanelHotkey" Visibility="Collapsed">

                        <TextBlock Text="단축키"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <!-- 채팅창 번역 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="채팅창 번역"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="채팅창을 한국어로 번역해요."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource HotkeyBadge}">
                                        <TextBlock x:Name="CaptureHotkeyLabel" Text="Ctrl + T"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                    </Border>
                                    <Button Content="변경" Style="{StaticResource SmallButton}"
                                            Margin="6,0,0,0" Click="OnChangeCaptureHotkey"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 입력창 번역 -->
                        <Border Margin="0,8,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="입력창 번역"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="내 채팅을 번역해 클립보드에 복사해요. Ctrl+V로 붙여넣으세요."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource HotkeyBadge}">
                                        <TextBlock x:Name="InputHotkeyLabel" Text="Ctrl + G"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                    </Border>
                                    <Button Content="변경" Style="{StaticResource SmallButton}"
                                            Margin="6,0,0,0" Click="OnChangeInputHotkey"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- ══════════ 탭3: 화면 ══════════ -->
                    <StackPanel x:Name="PanelScreen" Visibility="Collapsed">

                        <!-- 캡처 영역 -->
                        <TextBlock Text="채팅창 영역"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <RadioButton x:Name="RadioCaptureAuto" GroupName="CaptureRegion" IsChecked="True"
                                     Checked="OnCaptureRegionModeChanged">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="자동 (16:9 기준)" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{StaticResource CardBgBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="6,1" Margin="6,0,0,0">
                                    <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <RadioButton x:Name="RadioCaptureCustom" GroupName="CaptureRegion" VerticalAlignment="Center"
                                         Checked="OnCaptureRegionModeChanged">
                                <TextBlock Text="직접 지정" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </RadioButton>
                            <Button Content="영역 설정"
                                    Style="{StaticResource SmallButton}"
                                    IsEnabled="{Binding IsChecked, ElementName=RadioCaptureCustom}"
                                    Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="OnSetCaptureRegion"/>
                        </StackPanel>

                        <Separator/>

                        <!-- 오버레이 모니터 -->
                        <TextBlock Text="번역 오버레이를 표시할 모니터"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,16,0,10"/>

                        <ComboBox x:Name="MonitorCombo"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="OnMonitorChanged"/>

                        <Separator/>

                        <!-- 언어 변경 버튼 -->
                        <Border Margin="0,16,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="빠른 설정 오버레이"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="화면 왼쪽 위에 번역 언어와 음성 번역을 바로 전환할 수 있는 버튼을 표시해요."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ShowLangOverlayToggle"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="False"
                                                 Checked="OnShowLangOverlayChanged"
                                                 Unchecked="OnShowLangOverlayChanged"/>
                            </Grid>
                        </Border>

                        <!-- 오버레이 위치 편집 -->
                        <Border Margin="0,8,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="오버레이 편집"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="오버레이를 원하는대로 배치하고 편집할 수 있어요."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="편집"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource TabButtonActive}"
                                        Click="OnOverlayEditRequested"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                </Grid>
            </Border>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
