<Window x:Class="AlctClient.Views.Windows.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALCT 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Width="460" Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="OnWindowDrag">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.RowSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="28" Height="28" Margin="0,10,10,0"
                    ToolTip="앱 종료"
                    Click="OnCloseApp">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5" Padding="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="✕" FontSize="11"/>
            </Button>

            <!-- ═══════════════════ Step 0: Welcome ═══════════════════ -->
            <StackPanel x:Name="Step0Panel" Grid.Row="0"
                        Margin="40,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="LogoImage" Width="72" Height="72"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="ALCT에 오신 것을 환영합니다"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="ALCT는 온라인 게임에 특화된 오버레이 번역기입니다. 기능들을 차례로 소개할게요."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13" TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,0,36"/>
                <Button Content="시작하기" Style="{StaticResource AccentBtn}"
                        Width="240" Click="OnStep0Start"/>
            </StackPanel>

            <!-- ═══════════════════ Step 1: 채팅창 번역 소개 ═══════════════════ -->
            <StackPanel x:Name="StepChatPanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,0,36,0" VerticalAlignment="Center">
                <TextBlock Text="1 / 3 · 기능 소개"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,10"/>
                <TextBlock Text="💬 채팅창 번역"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="상대방의 채팅을 한국어로 화면에 띄워줘요."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <Border x:Name="ChatMediaBorder"
                        Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Margin="0,0,0,14" Height="190"
                        ClipToBounds="True">
                    <MediaElement x:Name="ChatDemoMedia"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Volume="0"
                                  MediaEnded="OnChatMediaEnded"/>
                </Border>

                <!-- 단축키 Pill -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7"
                        Padding="11,6" Margin="0,0,0,12"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="단축키  " FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ChatHotkeyLabel" FontSize="12" FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,0">
                    <TextBlock Text="단축키를 누르면 채팅을 번역해 오버레이로 보여줘요."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <Grid Margin="0,20,0,0">
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnChatBack"/>
                    <Button Content="다음 →" Style="{StaticResource AccentBtn}"
                            HorizontalAlignment="Right" Click="OnChatNext"/>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 2: 입력창 번역 소개 ═══════════════════ -->
            <StackPanel x:Name="StepInputPanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,0,36,0" VerticalAlignment="Center">
                <TextBlock Text="2 / 3 · 기능 소개"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,10"/>
                <TextBlock Text="⌨️ 입력창 번역"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="내가 쓴 채팅을 상대 언어로 번역해요."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Margin="0,0,0,14" Height="190"
                        ClipToBounds="True">
                    <MediaElement x:Name="InputDemoMedia"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Volume="0"
                                  MediaEnded="OnInputMediaEnded"/>
                </Border>

                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7"
                        Padding="11,6" Margin="0,0,0,12"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="단축키  " FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="InputHotkeyLabel" FontSize="12" FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}">
                    <TextBlock Text="채팅을 입력하고 단축키를 누르면 번역문이 클립보드에 복사돼요. Ctrl+V로 붙여넣으세요."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <Grid Margin="0,20,0,0">
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnInputBack"/>
                    <Button Content="다음 →" Style="{StaticResource AccentBtn}"
                            HorizontalAlignment="Right" Click="OnInputNext"/>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 3: 음성 번역 소개 ═══════════════════ -->
            <StackPanel x:Name="StepVoicePanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,0,36,0" VerticalAlignment="Center">
                <TextBlock Text="3 / 3 · 기능 소개"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🎙️ 실시간 음성 채팅 번역"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14">
                    음성 채팅을 실시간으로 번역해요. 음성이 감지되면 자동으로 자막이 생겨요.<Run Foreground="{StaticResource TextMutedBrush}"></Run>
                </TextBlock>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Margin="0,0,0,14" Height="190"
                        ClipToBounds="True">
                    <MediaElement x:Name="VoiceDemoMedia"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Volume="0"
                                  MediaEnded="OnVoiceMediaEnded"/>
                </Border>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}">
                    <TextBlock Text="사용하려면 Windows 11 Live Captions 언어팩 설치가 필요해요. 지금 설정할까요?"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <Grid Margin="0,20,0,0">
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnVoiceBack"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="나중에" Style="{StaticResource TextBtn}"
                                Margin="0,0,8,0" Click="OnVoiceSkip"/>
                        <Button Content="설정하기" Style="{StaticResource AccentBtn}"
                                Click="OnVoiceSetup"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 3b: 언어팩 설치 ═══════════════════ -->
            <StackPanel x:Name="StepVoiceSetupPanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,0,36,0" VerticalAlignment="Center">
                <TextBlock Text="3 / 3 · 언어팩 설치"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,10"/>
                <TextBlock Text="음성 번역 준비"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="아래 영상을 따라 목록에 표시된 Windows Live Captions 언어팩을 모두 설치해주세요. 약 1-3분 정도 소요돼요."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"/>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Margin="0,0,0,10" Height="168"
                        ClipToBounds="True">
                    <MediaElement x:Name="InstallGuideMedia"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Volume="0"
                                  MediaEnded="OnGuideMediaEnded"/>
                </Border>

                <Button Content="⚙️  라이브 캡션 창 열기"
                        Style="{StaticResource GhostBtn}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,10"
                        Click="OnOpenLiveCaptions"/>

                <!-- 언어팩 설치 상태 -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,6">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="JpIcon" Text="○" Grid.Column="0"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="일본어(일본)" Grid.Column="1" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="JpStatus" Grid.Column="2"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="확인 중..."/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ZhIcon" Text="○" Grid.Column="0"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="중국어(간체, 중국 본토)" Grid.Column="1" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ZhStatus" Grid.Column="2"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="확인 중..."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="언어팩이 설치되면 자동으로 확인돼요."
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,0"/>

                <Grid Margin="0,14,0,0">
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnVoiceSetupBack"/>
                    <Button x:Name="VoiceSetupNextBtn" Content="다음 →"
                            Style="{StaticResource AccentBtn}"
                            HorizontalAlignment="Right"
                            IsEnabled="False"
                            Click="OnVoiceSetupNext"/>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 4: 완료 ═══════════════════ -->
            <StackPanel x:Name="StepDonePanel" Grid.Row="0"
                        Visibility="Collapsed"
                        Margin="36,0,36,0" VerticalAlignment="Center">
                <Border Width="52" Height="52" CornerRadius="26"
                        Background="#1a4ade80"
                        HorizontalAlignment="Center" Margin="0,0,0,14">
                    <TextBlock Text="✓" FontSize="26" FontWeight="Bold"
                               Foreground="#4ade80"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="준비 완료!"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="이제 게임에서 ALCT를 바로 사용해 보세요."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,0,0,18"/>

                <!-- API key upsell card -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="💎  더 자연스러운 번역을 원하세요? (권장)"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,10"/>
                        <Border Background="{StaticResource InputBgBrush}"
                                CornerRadius="8" Height="180" Margin="0,0,0,10"
                                ClipToBounds="True">
                            <Image x:Name="QualityCompareImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="8"/>
                        </Border>
                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12">
                            DeepL·Gemini API 키를 등록하면 번역이 훨씬 자연스러워져요. 나중에 설정에서 언제든지 추가할 수 있어요.<Run Foreground="{StaticResource TextMutedBrush}"> (무료 플랜 지원)</Run>
                        </TextBlock>
                        <Button Content="키 등록하기 (선택)"
                                Style="{StaticResource GhostBtn}"
                                HorizontalAlignment="Stretch"
                                Click="OnApiUpsellRegister"/>
                    </StackPanel>
                </Border>

                <Button Content="시작하기" Style="{StaticResource AccentBtn}"
                        HorizontalAlignment="Stretch"
                        Click="OnComplete"/>
            </StackPanel>

            <!-- Progress Dots -->
            <StackPanel x:Name="DotsPanel" Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse x:Name="Dot0" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource AccentBrush}"/>
                <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
