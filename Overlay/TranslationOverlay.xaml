<Window x:Class="AlctClient.Overlay.TranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AlctClient.Overlay"
        Title="TranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="280">

    <Border x:Name="RootBorder"
            Background="{StaticResource OverlayBgBrush}"
            CornerRadius="{StaticResource CardRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">

        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="12,9,12,9">
                <Border Width="16" Height="16"
                        CornerRadius="4"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,7,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="A"
                               Foreground="White"
                               FontSize="9" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="ALCT 번역"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Translation entries -->
            <ItemsControl x:Name="EntriesList" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:TranslationEntry}">
                        <StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                            <StackPanel Margin="12,8,12,8">
                                <TextBlock Text="{Binding Translated}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Original}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
