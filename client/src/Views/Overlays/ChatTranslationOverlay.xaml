<Window x:Class="AlctClient.Views.Overlays.ChatTranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AlctClient.Views.Overlays"
        Title="ChatTranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="280"
        MinWidth="200" MaxWidth="600">

    <Border x:Name="RootBorder"
            Background="{StaticResource OverlayBgBrush}"
            CornerRadius="{StaticResource CardRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="OnMouseLeftButtonDown">

        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="12,9,12,9">
                <Ellipse Width="7" Height="7"
                         Fill="#4CAF50"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                <TextBlock Text="ALCT 채팅번역"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Translation entries -->
            <ItemsControl x:Name="EntriesList" Margin="0,0,0,4"
                          HorizontalContentAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:TranslationEntry}">
                        <StackPanel>
                            <Rectangle Height="1" Fill="{StaticResource BorderBrush}"/>
                            <StackPanel Margin="12,8,12,8">
                                <TextBlock Text="{Binding Translated}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Original}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 편집 모드 안내 바 (기본 숨김) -->
            <Border x:Name="EditModeBar"
                    Visibility="Collapsed"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="0,0,8,8"
                    Padding="0,5">
                <TextBlock Text="← 좌우 가장자리를 드래그하여 너비 조절 · 나머지 영역을 드래그하여 이동"
                           Foreground="White"
                           FontSize="10"
                           HorizontalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
