<Window x:Class="AlctClient.Views.Windows.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALCT 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Width="460" Height="620"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="16" Height="16" CornerRadius="3"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource InputBgBrush}" Margin="0,0,10,0">
                                <Path x:Name="CheckMark"
                                      Data="M 2,7 L 6,11 L 14,3"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="IsIndeterminate" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" ClipToBounds="True"
                                Height="{TemplateBinding Height}">
                            <Rectangle x:Name="GlowBar" Width="120"
                                       Fill="{TemplateBinding Foreground}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="GlowMove" X="-120"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="GlowMove"
                                                Storyboard.TargetProperty="X"
                                                From="-120" To="460" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.RowSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="28" Height="28" Margin="0,10,10,0"
                    ToolTip="앱 종료"
                    Click="OnCloseApp">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5" Padding="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <TextBlock Text="✕" FontSize="11"/>
            </Button>

            <!-- ═══════════════════ Step 0: Welcome ═══════════════════ -->
            <StackPanel x:Name="Step0Panel" Grid.Row="0"
                        Margin="40,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16"
                        Background="{StaticResource AccentBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Canvas Width="36" Height="36"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Bottom bubble (filled, semi-transparent) -->
                        <Path Fill="White" Opacity="0.55"
                              Data="M 10,22 Q 2,22 2,15 Q 2,8 10,8 Q 18,8 18,15 Q 18,19.5 14,21 L 16,26 Z"/>
                        <!-- Top bubble (outline) -->
                        <Path Stroke="White" StrokeThickness="1.8" Fill="Transparent"
                              StrokeLineJoin="Round"
                              Data="M 24,18 Q 16,18 16,11 Q 16,4 24,4 Q 32,4 32,11 Q 32,15.5 28,17 L 30,22 Z"/>
                    </Canvas>
                </Border>
                <TextBlock Text="ALCT에 오신 것을 환영합니다"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13" TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,0,36">
                    시작하려면 2가지만 설정하면 됩니다.&#x0a;천천히 안내해 드릴게요.
                </TextBlock>
                <Button Content="시작하기" Style="{StaticResource AccentBtn}"
                        Width="240" Click="OnStep0Start"/>
            </StackPanel>

            <!-- ═══════════════════ Step 1: DeepL Key ═══════════════════ -->
            <StackPanel x:Name="Step1Panel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,28,36,20">
                <TextBlock Text="1 / 4 단계"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,8"/>
                <TextBlock Text="번역 엔진 설정"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,20">
                    ALCT는 고품질 번역을 위해 DeepL API를 사용합니다. 키를 발급받지 않으면 번역을 사용할 수 없으니 꼭 발급받아주세요.(무료: 100만 자/월)
                </TextBlock>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource InputBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,1,0,1" CornerRadius="6,0,0,6">
                        <PasswordBox x:Name="ApiKeyBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     FontSize="13" Padding="10,8"
                                     PasswordChanged="OnApiKeyChanged"
                                     VerticalContentAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" Content="붙여넣기"
                            Click="OnPasteApiKey"
                            Cursor="Hand" Padding="12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="0,6,6,0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <TextBlock x:Name="ApiKeyStatus"
                           Text="DeepL API 키를 붙여넣거나 나중에 설정하세요."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"/>

                <Grid Margin="0,24,0,0">
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnBack1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="나중에 입력" Style="{StaticResource TextBtn}"
                                Margin="0,0,8,0" Click="OnSkipApiKey"/>
                        <Button Content="다음" Style="{StaticResource AccentBtn}"
                                Padding="20,9" Click="OnStep1Next"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 2a: Language Select ═══════════════════ -->
            <StackPanel x:Name="Step2aPanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,24,36,16">
                <TextBlock Text="2 / 4 단계"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,8"/>
                <TextBlock Text="음성 번역 언어팩 설치"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12">
                    음성 번역 활성화를 위해 Live Captions 언어팩 다운로드가 필요합니다. 이 과정은 한 번만 필요합니다. 아래 표시된 언어팩을 모두 다운받은 후 [설치 확인] 버튼을 눌러 계속 진행하세요.
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12">
                    [⚙] - [언어 변경]을 통해 추가 다운로드 가능합니다. 
                </TextBlock>
                

                <!-- GIF 안내 영역 -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Margin="0,0,0,12" Height="180"
                        ClipToBounds="True">
                    <MediaElement x:Name="InstallGuideMedia"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  MediaEnded="OnGuideMediaEnded"/>
                </Border>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12">
                    * 다운로드 시 시간이 약간 소요될 수 있습니다. (약 1-3분)
                </TextBlock>

            

                <!-- 언어 설치 상태 -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="일본어(일본)" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="JpStatus" Grid.Column="1"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="확인 중..."/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="중국어(간체, 중국 본토)" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ZhStatus" Grid.Column="1"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="확인 중..."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Button Content="창을 실수로 닫으셨나요? → 다시 열기"
                            FontSize="9"
                            Style="{StaticResource TextBtn}"
                            HorizontalAlignment="Left"
                            Click="OnOpenLiveCaptions"/>
                </Grid>

                <Grid>
                    <Button x:Name="LangBackBtn" Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnBack2a"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="건너뛰기" Style="{StaticResource GhostBtn}"
                                Margin="0,0,8,0" Click="OnSkipLanguage"/>
                        <Button x:Name="LangCheckBtn" Content="설치 확인"
                                Style="{StaticResource AccentBtn}" Click="OnCheckInstall"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 2c: Overlay Check ═══════════════════ -->
            <StackPanel x:Name="Step2cPanel" Grid.Row="0"
                        Visibility="Collapsed" Margin="36,28,36,20">
                <TextBlock Text="3 / 4 단계"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" Margin="0,0,0,8"/>
                <TextBlock Text="오버레이 위치 확인"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,24">
                    화면에 번역 오버레이가 표시됩니다. 드래그하여 원하는 위치로 이동하세요.
                </TextBlock>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                                     VerticalAlignment="Top" Margin="0,5,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="채팅 번역 오버레이"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="번역된 채팅 내용을 화면에 표시합니다."
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                                     VerticalAlignment="Top" Margin="0,5,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="음성 번역 오버레이"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="실시간 음성 번역 결과를 화면에 표시합니다."
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,24">
                    위치는 설정 → 오버레이 탭에서 언제든지 변경할 수 있습니다.
                </TextBlock>

                <Grid>
                    <Button Content="이전" Style="{StaticResource GhostBtn}"
                            HorizontalAlignment="Left" Click="OnBack2c"/>
                    <Button Content="확인 완료" Style="{StaticResource AccentBtn}"
                            Padding="24,9" HorizontalAlignment="Right"
                            Click="OnOverlayCheckDone"/>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════ Step 3: Complete ═══════════════════ -->
            <StackPanel x:Name="Step3Panel" Grid.Row="0"
                        Visibility="Collapsed"
                        Margin="40,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="28"
                        Background="#1a4ade80"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="✓" FontSize="28" FontWeight="Bold"
                               Foreground="#4ade80"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="설정 완료!"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="이제 게임에서 바로 사용할 수 있어요."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,0,0,24"/>

                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="{StaticResource CardRadius}"
                        Padding="{StaticResource CardPadding}"
                        Width="340" Margin="0,0,0,28">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="채팅창 번역"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock x:Name="CaptureHotkeyLabel"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="입력창 번역"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock x:Name="InputHotkeyLabel"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="시작하기" Style="{StaticResource AccentBtn}"
                        Width="240" Click="OnComplete"/>
            </StackPanel>

            <!-- Progress Dots -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse x:Name="Dot0" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource AccentBrush}"/>
                <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
                <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="5,0"
                         Fill="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
