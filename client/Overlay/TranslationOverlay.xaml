<Window x:Class="AlctClient.Overlay.TranslationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TranslationOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="620"
        Left="0" Top="860">
    <Border Background="#CC111111" CornerRadius="6" Margin="10,6">
        <TextBlock x:Name="TranslationText"
                   Foreground="White"
                   FontSize="15"
                   FontFamily="Malgun Gothic"
                   TextWrapping="Wrap"
                   Padding="12,8"/>
    </Border>
</Window>
