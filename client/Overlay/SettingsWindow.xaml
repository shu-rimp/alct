<Window x:Class="AlctClient.Overlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALCT"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Left="10" Top="10">
    <Border Background="#CC111111" CornerRadius="6" Padding="12,8">
        <StackPanel>
            <TextBlock Text="번역 언어" Foreground="#888888" FontSize="11"
                       FontFamily="Malgun Gothic" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioJA" Content="日本語" IsChecked="True"
                             Foreground="White" FontFamily="Malgun Gothic" FontSize="13"
                             Margin="0,0,14,0" Checked="OnLanguageChanged"/>
                <RadioButton x:Name="RadioZH" Content="中文"
                             Foreground="White" FontFamily="Malgun Gothic" FontSize="13"
                             Margin="0,0,14,0" Checked="OnLanguageChanged"/>
                <RadioButton x:Name="RadioEN" Content="English"
                             Foreground="White" FontFamily="Malgun Gothic" FontSize="13"
                             Checked="OnLanguageChanged"/>
            </StackPanel>
            <CheckBox x:Name="CaptionMonitorToggle" Content="라이브 캡션"
                      Foreground="White" FontFamily="Malgun Gothic" FontSize="13"
                      Margin="0,10,0,0"
                      Checked="OnCaptionModeChanged" Unchecked="OnCaptionModeChanged"/>
            <TextBlock Text="DeepL API 키" Foreground="#888888" FontSize="11"
                       FontFamily="Malgun Gothic" Margin="0,10,0,4"/>
            <TextBox x:Name="DeepLApiKeyBox"
                     FontFamily="Malgun Gothic" FontSize="12"
                     Width="200" HorizontalAlignment="Left"
                     Background="#1A1A1A" Foreground="White"
                     BorderBrush="#444444" Padding="4,2"
                     TextChanged="OnDeepLKeyChanged"/>
        </StackPanel>
    </Border>
</Window>
