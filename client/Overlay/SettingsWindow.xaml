<Window x:Class="AlctClient.Overlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ALCT 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        Width="480" Height="680"
        MinWidth="400" MinHeight="480">

    <Window.Resources>

        <!-- ── 탭 버튼: 활성 ── -->
        <Style x:Key="TabButtonActive" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 탭 버튼: 비활성 ── -->
        <Style x:Key="TabButtonInactive" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ── -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="root">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <Grid Margin="10,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                            <ToggleButton Style="{x:Null}"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, ElementName=root}"
                                        MaxHeight="180"
                                        Background="{StaticResource InputBgBrush}"
                                        BorderBrush="{StaticResource CardBorderAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 단축키 뱃지 ── -->
        <Style x:Key="HotkeyBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <!-- ── 소형 버튼 ── -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,16,0,0"/>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource SurfaceBgBrush}"
            CornerRadius="{StaticResource WindowRadius}"
            BorderBrush="{StaticResource CardBorderAccentBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="OnHeaderDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Grid Grid.Row="0" Margin="18,16,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="/assets/alct-wordmark.png" Height="32"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" HorizontalAlignment="Left"/>

                <Button Grid.Column="1" Content="✕"
                        Foreground="{StaticResource TextMutedBrush}"
                        FontSize="15" Click="OnClose">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="6">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ── 탭 바 (3개) ── -->
            <Border Grid.Row="1" Margin="18,12,18,0"
                    Background="{StaticResource CardBgBrush}"
                    CornerRadius="20" Padding="3">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TabTranslationBtn" Content="번역"
                            Style="{StaticResource TabButtonActive}"
                            Click="OnTabTranslation"/>
                    <Button x:Name="TabHotkeyBtn" Content="단축키"
                            Style="{StaticResource TabButtonInactive}"
                            Click="OnTabHotkey"/>
                    <Button x:Name="TabScreenBtn" Content="화면"
                            Style="{StaticResource TabButtonInactive}"
                            Click="OnTabScreen"/>
                </StackPanel>
            </Border>

            <!-- ── 콘텐츠 ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,18,20,26">
                <Grid>

                    <!-- ══════════ 탭1: 번역 ══════════ -->
                    <StackPanel x:Name="PanelTranslation" Visibility="Visible">

                        <!-- 번역 언어 -->
                        <TextBlock Text="번역 언어"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <RadioButton x:Name="RadioManual" GroupName="LanguageMode" IsChecked="True"
                                             Checked="OnLanguageModeChanged">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="수동 지정" FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource CardBgBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="6,1" Margin="6,0,0,0">
                                            <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="RadioAuto" GroupName="LanguageMode" Margin="0,12,0,0"
                                             Checked="OnLanguageModeChanged">
                                    <TextBlock Text="자동 감지" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </RadioButton>
                                <TextBlock x:Name="AutoDetectWarning"
                                           Visibility="Collapsed"
                                           Text="⚠ 자동 감지 설정 시 번역 품질이 낮아질 수 있습니다."
                                           Foreground="{StaticResource TextDangerBrush}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Margin="18,4,0,0"/>
                            </StackPanel>
                            <ComboBox x:Name="SourceLangCombo"
                                      Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      VerticalAlignment="Top"
                                      SelectionChanged="OnSourceLangChanged">
                                <ComboBoxItem Content="일본어" Tag="JA" IsSelected="True"/>
                                <ComboBoxItem Content="중국어" Tag="ZH"/>
                                <ComboBoxItem Content="영어"   Tag="EN"/>
                            </ComboBox>
                        </Grid>

                        <Separator/>

                        <!-- 번역 엔진 -->
                        <TextBlock Text="번역 엔진"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,16,0,10"/>

                        <RadioButton x:Name="RadioFree" GroupName="Engine" IsChecked="True"
                                     Checked="OnEngineChanged">
                            <TextBlock Text="Google"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </RadioButton>

                        <!-- DeepL 행: 라디오 + API키 입력 인라인 -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <RadioButton x:Name="RadioDeepL"
                                         GroupName="Engine"
                                         Grid.Column="0"
                                         VerticalAlignment="Center"
                                         Checked="OnEngineChanged">
                                <TextBlock Text="DeepL" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </RadioButton>

                            <Border Grid.Column="1" Margin="10,0,0,0"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ButtonRadius}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="{StaticResource ButtonRadius}"/>
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=RadioDeepL}" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock x:Name="ApiKeyPlaceholder"
                                               Text="API 키를 입력하세요"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" Padding="10,7"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="DeepLApiKeyBox"
                                                 Background="Transparent"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 CaretBrush="{StaticResource AccentBrush}"
                                                 BorderThickness="0"
                                                 FontSize="13" Padding="10,7"
                                                 IsEnabled="{Binding IsChecked, ElementName=RadioDeepL}"
                                                 PasswordChanged="OnDeepLKeyChanged"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Separator/>

                        <!-- 음성 번역 -->
                        <Border Margin="0,16,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="실시간 보이스 채팅 번역"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="인게임 보이스를 실시간으로 번역합니다.(Windows11 필수)"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="CaptionMonitorToggle"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="False"
                                                 Checked="OnCaptionModeChanged"
                                                 Unchecked="OnCaptionModeChanged"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- ══════════ 탭2: 단축키 ══════════ -->
                    <StackPanel x:Name="PanelHotkey" Visibility="Collapsed">

                        <TextBlock Text="단축키"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <!-- 채팅창 번역 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="채팅창 번역"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="채팅창의 채팅들을 한국어로 번역합니다."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource HotkeyBadge}">
                                        <TextBlock x:Name="CaptureHotkeyLabel" Text="Ctrl + T"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                    </Border>
                                    <Button Content="변경" Style="{StaticResource SmallButton}"
                                            Margin="6,0,0,0" Click="OnChangeCaptureHotkey"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 입력창 번역 -->
                        <Border Margin="0,8,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="입력창 번역"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="입력한 한국어 채팅을 대상 언어로 번역합니다."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource HotkeyBadge}">
                                        <TextBlock x:Name="InputHotkeyLabel" Text="Ctrl + G"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                    </Border>
                                    <Button Content="변경" Style="{StaticResource SmallButton}"
                                            Margin="6,0,0,0" Click="OnChangeInputHotkey"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- ══════════ 탭3: 화면 ══════════ -->
                    <StackPanel x:Name="PanelScreen" Visibility="Collapsed">

                        <!-- 캡처 영역 -->
                        <TextBlock Text="채팅창 영역"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <RadioButton x:Name="RadioCaptureAuto" GroupName="CaptureRegion" IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="자동 (16:9 기준)" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{StaticResource CardBgBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="6,1" Margin="6,0,0,0">
                                    <TextBlock Text="권장" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <RadioButton x:Name="RadioCaptureCustom" GroupName="CaptureRegion" VerticalAlignment="Center">
                                <TextBlock Text="직접 지정" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </RadioButton>
                            <Button Content="영역 설정"
                                    Style="{StaticResource SmallButton}"
                                    Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="OnSetCaptureRegion"/>
                        </StackPanel>

                        <Separator/>

                        <!-- 오버레이 모니터 -->
                        <TextBlock Text="번역 오버레이를 표시할 모니터"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="0,16,0,10"/>

                        <ComboBox x:Name="MonitorCombo"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="OnMonitorChanged"/>

                        <Separator/>

                        <!-- 언어 변경 버튼 -->
                        <Border Margin="0,16,0,0"
                                Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardRadius}"
                                Padding="{StaticResource CardPadding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="빠른 언어 변경 오버레이"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="게임 내 화면에 번역 언어를 변경할 수 있는 버튼을 표시합니다."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ShowLangOverlayToggle"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="False"
                                                 Checked="OnShowLangOverlayChanged"
                                                 Unchecked="OnShowLangOverlayChanged"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                </Grid>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
